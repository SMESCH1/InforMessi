# Variables de Entorno - InforMessi

# LLM - Proveedor y modelo
# Proveedores soportados: ollama, groq
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_BASE_URL=http://localhost:11434

# Groq API (fallback para GitHub Actions o si no hay Ollama local)
# Obtener API key gratuita en https://console.groq.com
GROQ_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_PREVIEW_CHAT_ID=your_preview_chat_id
TELEGRAM_PUBLIC_CHAT_ID=your_public_chat_id

# NewsAPI
NEWSAPI_KEY=your_newsapi_key

# Reddit
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=InforMessi/1.0

# Configuración General
MUNDIAL_2026_START_DATE=2026-06-11
TIMEZONE=America/Argentina/Buenos_Aires
