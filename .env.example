# InforMessi - Variables de Entorno
# Copiar este archivo como .env y completar con valores reales
# NUNCA commitear .env con valores reales

# LLM - Proveedor y modelo
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_BASE_URL=http://localhost:11434

# Groq API (alternativa cloud para GitHub Actions)
GROQ_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_PREVIEW_CHAT_ID=
TELEGRAM_PUBLIC_CHAT_ID=

# NewsAPI (opcional)
NEWSAPI_KEY=

# Reddit (opcional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=InforMessi/1.0
